# .env.example — copie para .env e preencha com seus valores reais
# NÃO suba o .env para o GitHub!

# Apify (https://apify.com → Settings → API & Integrations)
APIFY_TOKEN=seu_token_apify_aqui

# Anthropic Claude (https://platform.claude.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# Telegram Bot
TELEGRAM_TOKEN=123456789:AAFxxxxxxxxxxxxxxx

# ID do grupo Telegram
TELEGRAM_CHAT_ID=-100123456789

# PostgreSQL (Railway fornece automaticamente ao adicionar um plugin Postgres)
DATABASE_URL=postgresql://usuario:senha@host:5432/banco
